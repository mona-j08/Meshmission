rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ───────────────────────────────────────
    
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuth() && (
        request.auth.token.role == 'admin' ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // ─── users COLLECTION ───────────────────────────────────────
    
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId) && request.resource.data.role in ['donor', 'volunteer', 'ngo', 'admin'];
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── donations COLLECTION ───────────────────────────────────
    
    match /donations/{donationId} {
      allow read: if isAuth();
      allow create: if isAuth() && 
        request.resource.data.donorId == request.auth.uid &&
        (request.resource.data.status == 'pending' || request.resource.data.status == 'uploaded');
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // ─── ngo_profiles COLLECTION ────────────────────────────────
    
    match /ngo_profiles/{ngoId} {
      allow read: if isAuth();
      allow create: if isOwner(ngoId);
      allow update: if isOwner(ngoId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── ngo_requirements COLLECTION ────────────────────────────
    
    match /ngo_requirements/{reqId} {
      allow read: if isAuth();
      allow create: if isAuth() && 
        request.resource.data.ngoId == request.auth.uid;
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    // ─── volunteers COLLECTION ──────────────────────────────────
    
    match /volunteers/{volunteerId} {
      allow read: if isAuth();
      allow create: if isOwner(volunteerId);
      allow update: if isOwner(volunteerId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── pickup_tasks COLLECTION ────────────────────────────────
    
    match /pickup_tasks/{taskId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin();

      // PII subcollection protection
      match /private/{docId} {
        allow read: if isAuth();
        allow create, update, delete: if false; // Cloud Functions only
      }
    }

    // ─── collection_points COLLECTION ───────────────────────────
    
    match /collection_points/{pointId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // ─── deliveries COLLECTION ──────────────────────────────────
    
    match /deliveries/{deliveryId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin();
    }

    // ─── notifications COLLECTION ───────────────────────────────
    
    match /notifications/{notifId} {
      allow read: if isAuth();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
      allow delete: if false;
    }

    // ─── impact COLLECTION ──────────────────────────────────────
    
    match /impact/{docId} {
      allow read: if isAuth();
      allow create, update, delete: if false; // Admin SDK only
    }

    // ─── matches COLLECTION ─────────────────────────────────────
    
    match /matches/{matchId} {
      allow read: if isAuth();
      allow create, update, delete: if false; // Admin SDK only
    }

    // Default deny rule
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
